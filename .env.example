# Copy to .env and fill in. Never commit .env.

# --- Database ---
POSTGRES_USER=bank
POSTGRES_PASSWORD=bank
POSTGRES_DB=bank
# Services connect as the least-privilege app_user (append-only on audit_log).
DATABASE_URL=postgres://app_user:app_user@localhost:5432/bank?sslmode=disable

# --- Auth ---
# HMAC-SHA256 secret shared by the gateway (signs) and MCP server (verifies).
# Change this in any non-dev environment.
JWT_SECRET=dev-only-change-in-prod
JWT_ISSUER=banking-agent
JWT_AUDIENCE=banking-agent

# --- LLM / Embeddings (M2 / M5) ---
# Google AI Studio key — free tier at aistudio.google.com
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5-lite
FAISS_INDEX_PATH=./python/.faiss_index   # on-disk FAISS index, built by `make ingest`

# --- Observability (M9) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=banking-agent

# --- Agent (M3) ---
# Postgres checkpointer — agent_user has access only to LangGraph checkpoint tables.
# Inside Docker the agent uses @postgres; outside Docker use @localhost.
CHECKPOINT_DB_URL=postgresql://agent_user:agent_user@localhost:5432/bank

# --- Service wiring ---
GATEWAY_ADDR=:8080
MCP_SERVER_ADDR=:7070
# Host-side default; inside Docker the agent uses host.docker.internal instead.
MCP_SERVER_URL=http://localhost:7070/mcp
AGENT_URL=http://localhost:8000
